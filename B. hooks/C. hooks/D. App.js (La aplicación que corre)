import React from 'react';
import { StyleSheet, Text, View, TouchableOpacity, Alert } from 'react-native';
import { Camera } from 'expo-camera';
import { useCameraManager } from './hooks/useCameraManager';
import { useLocationManager } from './hooks/useLocationManager';

export default function App() {
  const { hasPermission, setCameraRef, requestCameraPermission, takePicture } = useCameraManager();
  const { location, errorMsg, getPosition } = useLocationManager();

  const handleCameraAction = async () => {
    const granted = await requestCameraPermission();
    if (!granted) {
      Alert.alert("Error", "Permiso de cámara denegado"); // Captura 4
    }
  };

  return (
    <View style={styles.container}>
      <Text style={styles.title}>SecureNode Solutions</Text>

      {/* Sección GPS */}
      <View style={styles.section}>
        <TouchableOpacity style={styles.button} onPress={getPosition}>
          <Text style={styles.buttonText}>Obtener Ubicación</Text>
        </TouchableOpacity>
        {location && (
          <Text>Lat: {location.coords.latitude}, Lon: {location.coords.longitude}</Text>
        )}
      </View>

      {/* Sección Cámara */}
      <View style={styles.section}>
        <TouchableOpacity style={styles.button} onPress={handleCameraAction}>
          <Text style={styles.buttonText}>Activar Cámara</Text>
        </TouchableOpacity>
        
        {hasPermission && (
          <Camera style={styles.camera} ref={(ref) => setCameraRef(ref)}>
             <TouchableOpacity style={styles.captureBtn} onPress={takePicture}>
                <View style={styles.innerBtn} />
             </TouchableOpacity>
          </Camera>
        )}
      </View>
    </View>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, paddingTop: 50, alignItems: 'center', backgroundColor: '#f5f5f5' },
  title: { fontSize: 24, fontWeight: 'bold', marginBottom: 20 },
  section: { width: '90%', padding: 20, backgroundColor: '#fff', borderRadius: 10, marginBottom: 20 },
  button: { backgroundColor: '#007AFF', padding: 15, borderRadius: 8, alignItems: 'center' },
  buttonText: { color: '#fff', fontWeight: 'bold' },
  camera: { width: '100%', height: 300, marginTop: 10, justifyContent: 'flex-end', alignItems: 'center' },
  captureBtn: { width: 70, height: 70, borderRadius: 35, backgroundColor: 'rgba(255,255,255,0.3)', justifyContent: 'center', alignItems: 'center', marginBottom: 20 },
  innerBtn: { width: 50, height: 50, borderRadius: 25, backgroundColor: 'white' }
});
